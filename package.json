{
  "name": "mod-update-checker",
  "version": "1.0.0",
  "description": "Discord bot that polls stores for project updates",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "dotenvx run -- node dist/index.js",
    "dev": "dotenvx run -- ts-node src/index.ts",
    "deploy-commands": "dotenvx run -- ts-node src/deploy-commands.ts"
  },
  "dependencies": {
    "@dotenvx/dotenvx": "^1.0.0",
    "discord.js": "^14.15.0",
    "pg": "^8.12.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/pg": "^8.11.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.4.0"
  }
}
